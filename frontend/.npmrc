# ─── Supply Chain Security ───────────────────────────────────────
# Prevent installing packages published less than 7 days ago.
# Mitigates "publish and immediately poison" supply chain attacks.
# See: https://docs.npmjs.com/cli/configuring-npm/npmrc#min-release-age
min-release-age = 7d

# ─── Strict Settings ─────────────────────────────────────────────
# Disable package-lock.json merge conflicts (use --lockfile-verison to update)
lockfile-version = 3

# Keep exact versions for critical infra (when using --save-exact with npm install)
save-exact = false

# Disable audit warnings (run `npm audit` separately when needed)
audit = false
